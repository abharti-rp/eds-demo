# CORS Headers for AEM Editor Support
<IfModule mod_headers.c>
  # Allow requests from AEM author domain
  SetEnvIf Origin "^https://author-p133739-e1306963\.adobeaemcloud\.com$" CORS_ALLOWED=true
  
  # Set CORS headers if origin is allowed
  Header set Access-Control-Allow-Origin "*" env=CORS_ALLOWED
  Header set Access-Control-Allow-Methods "GET, HEAD, OPTIONS" env=CORS_ALLOWED
  Header set Access-Control-Allow-Headers "Content-Type, Authorization" env=CORS_ALLOWED
  Header set Access-Control-Allow-Credentials "true" env=CORS_ALLOWED
</IfModule>

# Handle OPTIONS requests
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_METHOD} OPTIONS
  RewriteRule ^(.*)$ - [L]
</IfModule>
